{
  "expo": {
    "name": "MyLibrary",
    "slug": "mylibrary",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mylibrary",
    "userInterfaceStyle": "automatic",
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      [
        "expo-navigation-bar",
        {
          "backgroundColor": "#100D08",
          "barStyle": "light",
          "borderColor": "#100D08",
          "position": "relative",
          "visibility": "visible"
        }
      ],
      "expo-video"
    ],
    "assetBundlePatterns": [
      "**/*"
    ]
  }
}
