{
  "expo": {
    "name": "MyLibrary",
    "slug": "mylibrary",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mylibrary",
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      [
        "expo-navigation-bar",
        {
          "backgroundColor": "#100D08",
          "barStyle": "light",
          "borderColor": "#100D08",
          "behavior": "overlay-swipe",
          "position": "absolute",
          "visibility": "visible"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow MyLibrary to access your camera for OCR scanning."
        }
      ],
      "expo-dev-client",
      "react-native-fast-tflite",
      "expo-video",
      "expo-sqlite"
    ],
    "androidStatusBar": {
      "backgroundColor": "#100D08",
      "barStyle": "light-content",
      "translucent": true
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.mylibrary"
    }
  }
}
