{
  "expo": {
    "name": "MyLibrary",
    "slug": "mylibrary",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mylibrary",
    "userInterfaceStyle": "automatic",
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      [
        "expo-navigation-bar",
        {
          "backgroundColor": "#00000000",
          "barStyle": "light",
          "borderColor": "#00000000",
          "behavior": "overlay-swipe",
          "position": "absolute",
          "visibility": "visible"
        }
      ],
      "expo-video",
      "expo-sqlite"
    ],
    "androidStatusBar": {
      "backgroundColor": "#00000000",
      "barStyle": "light-content",
      "translucent": true
    },
    "assetBundlePatterns": [
      "**/*"
    ]
  }
}
