{
  "name": "mylibrary",
  "version": "1.0.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start --dev-client",
    "start:dev-client": "expo start --dev-client",
    "android": "expo run:android",
    "android:dev": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild:android": "expo prebuild --platform android",
    "assets:blend": "python assets_pipeline/run_pipeline.py",
    "assets:copy": "python assets_pipeline/copy_assets.py"
  },
  "dependencies": {
    "expo": "~54.0.34",
    "expo-camera": "~17.0.10",
    "expo-dev-client": "~6.0.21",
    "expo-navigation-bar": "~5.0.10",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-video": "~3.0.16",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-fast-tflite": "^3.0.1",
    "react-native-nitro-modules": "^0.35.6"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "typescript": "~5.9.2"
  }
}
